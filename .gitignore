.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.env

/media

# WordPress migration scrape (source content + downloaded images) — read at
# migration time only; never committed (media lives in object storage, not the repo).
/lallafatema-content

# Magazine issue PDFs (source for the magazine import) — hundreds of MB, read at
# import time only; the files live in object storage (Vercel Blob), never in the repo.
/magazines

